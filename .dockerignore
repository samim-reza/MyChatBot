# Docker ignore for FAST build (includes venv)
# Git and repo-local tooling
.git
**/.git
.gitignore
.github
.agents
.codex

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Documentation  
*.md
!README.md

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment
.env
.env.*
venv/
portfolio/.env*
portfolio/.husky/
portfolio/.vercel/
portfolio/coverage/
portfolio/node_modules/
portfolio/out/
portfolio/.next/
portfolio/npm-debug.log*
portfolio/yarn-debug.log*
portfolio/yarn-error.log*
portfolio/.pnpm-debug.log*

# Generated runtime data mounted as a volume by docker-compose.yml
data/chroma_db/

# Logs
*.log

# Test files
test_*.py

# Backups
chroma_db.backup/
*.bak

# Personal info (keep this excluded for security)
data/personal.json
data/cv.tex
messages/
credentials.txt
for_github.json
