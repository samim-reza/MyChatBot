# Docker ignore for FAST build (includes venv)
# Git
.git
.gitignore
.github

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Documentation  
*.md
!README.md

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment
.env
venv/
samim-reza/node_modules/
samim-reza/static/
samim-reza/asset-manifest.json
samim-reza/.codex/
samim-reza/.agents/

# Logs
*.log

# Test files
test_*.py

# Backups
chroma_db.backup/
*.bak

# Personal info (keep this excluded for security)
data/personal.json
credentials.txt
